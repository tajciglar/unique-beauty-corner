generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model Appointment {
  id        Int      @id @default(autoincrement())
  date      String
  startTime String
  endTime   String
  available Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order?

  @@index([date, available])
  @@index([date, startTime])
}

model Order {
  id            Int         @id @default(autoincrement())
  name          String
  email         String
  phone         String
  price         Decimal @db.Decimal(10, 2)
  duration      Int
  appointmentId Int         @unique // Ensures one-to-one relationship
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  services      Services[]
  checkedIn     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([createdAt])
}

model ServiceCategory {
  id                  Int        @id @default(autoincrement())
  categoryName        String     @unique
  categoryDescription String?
  services            Services[]
}

model Services {
  id                 Int             @id @default(autoincrement())
  serviceName        String
  servicePrice       Decimal @db.Decimal(10, 2)
  serviceTime        Int? // Optional time field (in minutes)
  serviceDescription String? // Optional description field
  serviceCategoryId  Int
  displayOrder       Int
  serviceCategory    ServiceCategory @relation(fields: [serviceCategoryId], references: [id])
  Order              Order?          @relation(fields: [OrderId], references: [id])
  OrderId            Int?
}

model Notification {
  id        Int              @id @default(autoincrement())
  message   String
  type      NotificationType
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

enum NotificationType {
  info
  success
  warning
  alert
}
